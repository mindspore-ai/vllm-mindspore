Pattern ConvertAtenEmbedding {
  let root = op<torch.aten.embedding>(
    weight: Value, indices: Value,
    padding_idx: Value, scale_grad_by_freq: Value, sparse: Value
  ) -> (resType: Type);
  replace root with op<mrt.embedding>(
    convertValue(weight), convertValue(indices)
  ) -> (convertType(resType));
}

